{
  "name": "Post Service",
  "api_id": "post-service",
  "org_id": "default",
  "definition": {
    "location": "header",
    "key": "x-api-version"
  },
  "use_keyless": false,
  "enable_jwt": true,
  "jwt_signing_method": "hmac",
  "jwt_source": "EAJYjNJUnRGJ6uq1YfGw4NG1pd1z102J",
  "jwt_identity_base_field": "sub",
  "jwt_policy_field_name": "pol",
  "jwt_default_policies": [
    "default_policy"
  ],
  "jwt_issued_at_validation_skew": 0,
  "jwt_expires_at_validation_skew": 0,
  "jwt_not_before_validation_skew": 0,
  "jwt_skip_kid": false,
  "jwt_scope_to_policy_mapping": {},
  "jwt_scope_claim_name": "scope",
  "auth": {
    "auth_header_name": "Authorization",
    "use_param": false,
    "param_name": "",
    "use_cookie": false,
    "cookie_name": "",
    "pass_through": true
  },
  "version_data": {
    "not_versioned": true,
    "versions": {
      "Default": {
        "name": "Default",
        "use_extended_paths": true,
        "global_headers": {
            "x-tyk-override": "tyk-gateway"
        },
         "global_headers_remove": [
            "x-tyk-override"
        ],
        "extended_paths": {
          "ignored": [
            {
              "path": "/post/health",
              "method_actions": {
                "GET": {
                  "action": "no_action",
                  "code": 200,
                  "data": {}
                }
              }
            }
          ],
          "cache": [
             "GET"
          ]
        },
        "cache_options": {
            "cache_timeout": 60,
            "enable_cache": true,
            "cache_all_safe_requests": false,
            "cache_response_codes": [
                200
            ]
        }
      }
    }
  },
  "proxy": {
    "listen_path": "/post/",
    "target_url": "http://post-service:9002/v1/post/",
    "strip_listen_path": true
  },
  "global_rate_limit": {
    "rate": 200,
    "per": 60
  },
  "active": true
}
