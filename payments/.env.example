# Environment
NODE_ENV=development

# App Config
APP_NAME="Payments Service"
HTTP_HOST=0.0.0.0
HTTP_PORT=9006
GRPC_URL=0.0.0.0:50056

# Database
DATABASE_URL="postgresql://admin:master123@localhost:15436/payments?schema=public"

# Cache & Messaging
