NODE_ENV="local"

APP_NAME="@backendworks/auth"
APP_CORS_ORIGINS="*"
APP_DEBUG=true

HTTP_ENABLE=true
HTTP_HOST="0.0.0.0"
HTTP_PORT=9001
HTTP_VERSIONING_ENABLE=true
HTTP_VERSION=1

SENTRY_DSN=""

# Secrets injected via Docker Compose
# DATABASE_URL=...
# ACCESS_TOKEN_SECRET_KEY=...
# REFRESH_TOKEN_SECRET_KEY=...

REDIS_URL="redis://redis:6379"
REDIS_KEY_PREFIX="auth:"
REDIS_TTL=3600

GRPC_URL="0.0.0.0:50051"
GRPC_PACKAGE="auth"
