generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique
  items     Json     @default("[]") // [{ productId, quantity, price, name, image }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carts")
}
